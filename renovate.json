{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:automergeDaily"'
    ":disableDependencyDashboard"
  ],
  "labels": [
    "dependencies",
    "renovate"
  ],
  "platformAutomerge": true,
  "automergeType": "pr",
  "packageRules": [
    {
      "description": "Automerge ALL updates immediately",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "matchPackageNames": [
        "*"
      ]
    }
  ]
}

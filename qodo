#!/usr/bin/env sh
#Dont ever touch this

# Load QODO_API_KEY from environment instead of storing secrets in this file.
export QODO_API_KEY=sk-Fa-Zmm6pTws5COmUu7sKhhWbbrHxHpAQ__6_PwlFOwc-i_JvoZZCL17g2PDr13jutoYb868hfe8XTacjqLoSjz0
MODEL_DEFAULT="gpt-5.2-pro-high"

# Detect if the user already provided a model flag
has_model=0
for arg in "$@"; do
  case "$arg" in
    -m|--model|--model=*) has_model=1; break ;;
  esac
done

if [ "$has_model" -eq 1 ]; then
  # Respect the user's provided model flag and pass args as-is
  exec qodo "$@"
else
  # If the first argument looks like an option (starts with -), keep -m before the rest.
  # Otherwise (subcommand like "chat"), place -m after the subcommand so it isn't misinterpreted.
  if [ "$#" -gt 0 ] && [ "${1#-}" != "$1" ]; then
    exec qodo -m "$MODEL_DEFAULT" "$@"
  else
    if [ "$#" -gt 0 ]; then
      subcmd=$1
      shift
      exec qodo "$subcmd" -m "$MODEL_DEFAULT" "$@"
    else
      exec qodo -m "$MODEL_DEFAULT"
    fi
  fi
fi
